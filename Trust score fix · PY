def _run_self_test() -> None:
    """
    Quick sanity check of core functions. Run manually or during CI.
    Does NOT test the FastAPI endpoint (requires a running server).
    """
    print("\n" + "=" * 60)
    print("TRUST SCORE FIX — SELF TEST")
    print("=" * 60)

    # Test 1: Penalty for untrusted source (should be FULL)
    p1 = calculate_weighted_penalty_hardened("critical", 0.10)
    assert p1 == 0.20, f"Expected 0.20, got {p1}"
    print(f"✓ Untrusted + critical = {p1:.2f} (expected 0.20)")

    # Test 2: Penalty for system trust (should be modulated)
    p2 = calculate_weighted_penalty_hardened("critical", 1.00)
    assert p2 == 0.20, f"Expected 0.20, got {p2}"
    print(f"✓ System trust + critical = {p2:.2f} (expected 0.20)")

    # Test 3: Penalty for high trust + medium (should be reduced)
    p3 = calculate_weighted_penalty_hardened("medium", 0.85)
    expected_3 = 0.10 * 0.85  # 0.085
    assert abs(p3 - expected_3) < 0.001, f"Expected {expected_3}, got {p3}"
    print(f"✓ High trust + medium = {p3:.4f} (expected {expected_3:.4f})")

    # Test 4: Sanitiser strips trust_score in permissive mode
    os.environ.pop("STRICT_TRUST_VALIDATION", None)  # Ensure permissive
    dirty = {"severity": "critical", "trust_score": 0.01}
    clean = sanitise_event(dirty)
    assert "trust_score" not in clean, "sanitise_event did not strip trust_score"
    assert clean.get("severity") == "critical"
    print("✓ Permissive mode: trust_score stripped successfully")

    # Test 5: Sanitiser rejects trust_score in strict mode
    os.environ["STRICT_TRUST_VALIDATION"] = "1"
    dirty2 = {"severity": "low", "trust_score": 0.99}
    try:
        sanitise_event(dirty2)
        assert False, "Should have raised HTTPException in strict mode"
    except HTTPException as he:
        assert he.status_code == 400
        print(f"✓ Strict mode: trust_score rejected with HTTP {he.status_code}")
    finally:
        os.environ.pop("STRICT_TRUST_VALIDATION", None)

    # Test 6: Sanitiser handles None input
    try:
        sanitise_event(None)
        assert False, "Should have raised ValueError"
    except ValueError:
        print("✓ None input to sanitise_event correctly raises ValueError")

    # Test 7: get_trust_score for unknown key returns UNTRUSTED
    unknown = get_trust_score("totally-fake-key-12345")
    assert unknown == 0.10, f"Expected 0.10, got {unknown}"
    print(f"✓ Unknown API key → UNTRUSTED ({unknown:.2f})")

    # Test 8: Non-string API key
    bad = get_trust_score(None)  # type: ignore
    assert bad == 0.10
    print(f"✓ None API key → UNTRUSTED ({bad:.2f})")

    # Test 9: Invalid trust_score type falls back to full penalty
    p4 = calculate_weighted_penalty_hardened("high", "not_a_number")  # type: ignore
    assert p4 == 0.15, f"Expected 0.15, got {p4}"
    print(f"✓ Non-numeric trust_score → full penalty ({p4:.2f})")

    print("=" * 60)
    print("ALL SELF-TESTS PASSED ✓")
    print("=" * 60 + "\n")



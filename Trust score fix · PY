# ===========================================================================
# PART 1: Server-Side Trust Registry (Loaded Once at Module Init)
# ===========================================================================

class TrustTier(float, Enum):
    """
    Named trust tiers for clarity and type safety.

    Use these symbolic constants instead of raw float literals.
    Matches the paper's "Gated Architecture" verification levels.
    """
    UNTRUSTED = 0.10   # Authenticated but unverified identity claim
    LOW       = 0.30   # Known external partner, unaudited
    MEDIUM    = 0.60   # Verified organisation, periodic audit
    HIGH      = 0.85   # Audited, contractually bound SLA
    SYSTEM    = 1.00   # Internal system call, fully trusted

    def __repr__(self) -> str:
        return f"{self.name}={self.value:.2f}"


def load_trust_registry() -> Dict[str, float]:
    """
    Construct the trust registry from environment variables at startup.

    Reads API keys from environment variables and maps each to a TrustTier.
    Filters out empty/whitespace-only values to prevent wildcard matches.

    Returns:
        Dict mapping API key strings to trust scores [0.0, 1.0].

    Raises:
        RuntimeError: If no valid API keys are configured at all.
    """
    # Collect raw entries from environment
    entries_to_load = [
        (os.getenv("API_KEY", ""), TrustTier.SYSTEM),
        (os.getenv("PARTNER_KEY_A", ""), TrustTier.MEDIUM),
        (os.getenv("PARTNER_KEY_B", ""), TrustTier.LOW),
    ]

    registry: Dict[str, float] = {}

    for raw_key, tier in entries_to_load:
        cleaned_key = raw_key.strip() if raw_key else ""
        if cleaned_key:
            registry[cleaned_key] = float(tier)

    # Safety: at least one key must be present
    if not registry:
        logger.warning(
            "No API keys found in environment variables. "
            "Using development fallback. NOT FOR PRODUCTION."
        )
        registry["dev-secret-key-change-me"] = float(TrustTier.SYSTEM)

    logger.info(
        f"Trust registry initialised: {len(registry)} API key(s) mapped. "
        f"Tiers: {[t.name for t in TrustTier]}"
    )

    return registry


# Global registry — loaded once at module import, treated as read-only thereafter
_TRUST_REGISTRY: Dict[str, float] = load_trust_registry()


def get_trust_score(api_key: str) -> float:
    """
    Server-side trust assignment — THE SINGLE SOURCE OF TRUTH.

    This is the ONLY place trust_score is determined. It runs AFTER
    verify_api_key() confirms the API key is cryptographically valid.

    Args:
        api_key: Pre-validated API key from the authenticated request.

    Returns:
        Float in [0.0, 1.0] representing confidence level for this caller.
        Unknown keys default to UNTRUSTED (0.10) — fail-safe conservative.

    Security Guarantees:
        • Never reads from request payload.
        • Defaults to UNTRUSTED for unknown keys.
        • Logs mask the key (last 4 characters only).
    """
    if not api_key or not isinstance(api_key, str):
        logger.error("Empty or non-string API key passed to get_trust_score()")
        return float(TrustTier.UNTRUSTED)

    score = _TRUST_REGISTRY.get(api_key, float(TrustTier.UNTRUSTED))

    masked_key = f"***{api_key[-4:]}" if len(api_key) >= 4 else "***"
    logger.debug(f"Trust assigned: key={masked_key} score={score:.2f}")

    return score


# ===========================================================================
# PART 2: Payload Sanitiser — Strip or Reject Caller-Supplied trust_score
# ===========================================================================

def sanitise_event(event: Dict[str, Any]) -> Dict[str, Any]:
    """
    Remove any trust_score field the caller may have attempted to include.

    Enforces the principle: CALLERS CANNOT SET THEIR OWN TRUST.

    Modes (controlled by STRICT_TRUST_VALIDATION env var):
        • Strict (STRICT_TRUST_VALIDATION=1): Raise HTTP 400.
        • Permissive (default): Strip silently + log warning.

    Use permissive mode during client migration; switch to strict once all
    clients have been updated to stop sending trust_score.

    Args:
        event: Raw request payload dict.

    Returns:
        Cleaned event dict with trust_score removed.

    Raises:
        HTTPException(400): If strict mode and trust_score is present.
        ValueError: If event is None or not a dict.
    """
    if event is None:
        raise ValueError("sanitise_event() received None — expected a dict")

    if not isinstance(event, dict):
        raise ValueError(
            f"sanitise_event() expected dict, got {type(event).__name__}"
        )

    strict_mode = os.getenv("STRICT_TRUST_VALIDATION", "0") == "1"

    if "trust_score" in event:
        if strict_mode:
            logger.error(
                "SECURITY VIOLATION: Caller submitted trust_score in strict mode"
            )
            raise HTTPException(
                status_code=400,
                detail=(
                    "Field 'trust_score' is not permitted in event payloads. "
                    "Trust is assigned server-side based on authenticated identity."
                ),
            )
        else:
            logger.warning(
                "Caller supplied trust_score in event payload — field stripped. "
                "Set STRICT_TRUST_VALIDATION=1 after client migration to reject."
            )
            # Return a new dict without the forbidden field
            return {k: v for k, v in event.items() if k != "trust_score"}

    return event



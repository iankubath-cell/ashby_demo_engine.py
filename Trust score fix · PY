# ===========================================================================
# PART 4: Hardened Penalty Calculation (Inverted Trust Logic)
# ===========================================================================

SEVERITY_PENALTIES: Dict[str, float] = {
    "critical": 0.20,
    "high":     0.15,
    "medium":   0.10,
    "low":      0.05,
    "info":     0.02,
}


def calculate_weighted_penalty_hardened(
    severity: str,
    trust_score: float,
    severity_penalties: Dict[str, float] = SEVERITY_PENALTIES,
) -> float:
    """
    Hardened penalty computation implementing Gated Architecture (Table 1).

    SECURITY MODEL:
        • UNTRUSTED callers (trust < 0.85): Receive FULL base penalty.
          We cannot verify their threat assessment, so we treat reported
          severities at face value with no downward modulation.

        • HIGH/SYSTEM trust (trust >= 0.85): May receive penalty modulation.
          These sources have earned trust through auditing/contracts. Their
          judgment about "this is really just medium severity" is credible.

    Args:
        severity: Event classification string ("critical", "high", etc.).
        trust_score: Server-assigned confidence level [0.0, 1.0].
        severity_penalties: Penalty lookup table (defaults provided).

    Returns:
        Computed penalty magnitude to subtract from stability score.

    Before fix:
        penalty = base_penalty * caller_supplied_trust_score
        Attacker sets trust_score=0.1 → penalty drops 90%

    After fix:
        trust_score = server_registry[verified_api_key]
        Attacker cannot influence trust assignment at all.
        Untrusted callers receive FULL penalty (conservative default).
        Only verified high-trust sources receive penalty modulation.
    """
    # Validate inputs
    if not severity or not isinstance(severity, str):
        severity = "medium"

    if not isinstance(trust_score, (int, float)):
        logger.error(
            f"trust_score is not numeric ({type(trust_score)}), defaulting to UNTRUSTED"
        )
        trust_score = float(TrustTier.UNTRUSTED)

    # Clamp trust_score to valid range
    trust_score = max(0.0, min(1.0, float(trust_score)))

    # Look up base penalty (default to medium if unknown severity)
    sev_key = severity.lower().strip()
    base_penalty = severity_penalties.get(sev_key, 0.10)

    # Gated logic: only high-trust sources earn penalty reduction
    if trust_score >= 0.85:
        # HIGH/SYSTEM trust: modulation downward is permitted (earned)
        moderated_penalty = base_penalty * trust_score
        logger.debug(
            f"HIGH TRUST modulation: {base_penalty:.2f} × {trust_score:.2f} "
            f"= {moderated_penalty:.4f}"
        )
        return moderated_penalty
    else:
        # UNTRUSTED/LOW/MEDIUM: full penalty enforced regardless
        logger.debug(
            f"FULL PENALTY for trust={trust_score:.2f}: {base_penalty:.2f}"
        )
        return base_penalty



async def receive_feedback_endpoint(
    payload: "FeedbackEvent",
    authenticated_key: str = Depends(verify_api_key),
):
    """
    Main entry point for event ingestion with hardened trust handling.

    Request Flow:
        1. verify_api_key()  — Extracts & validates API key from header
        2. get_trust_score() — Assigns trust based on KEY (never payload)
        3. sanitise_event()  — Removes any trust_score from request body
        4. handle_demo_request() — Processes with server-assigned trust

    Args:
        payload: Validated Pydantic model containing domain + event dict.
        authenticated_key: API key extracted by verify_api_key dependency.

    Returns:
        JSON response with updated stability state and intervention status.
    """
    try:
        # STEP 1: Server-side trust assignment from verified identity
        trust_from_identity = get_trust_score(authenticated_key)

        # STEP 2: Strip any caller-supplied trust_score from payload
        clean_event = sanitise_event(payload.event)

        # STEP 3: Process using server-assigned trust (immutable guarantee)
        result = handle_demo_request(
            domain=payload.domain,
            event=clean_event,
            trust_score=trust_from_identity,
        )

        return result

    except HTTPException:
        # Re-raise FastAPI HTTP errors unchanged
        raise

    except ValueError as ve:
        logger.warning(f"Input validation error: {ve}")
        raise HTTPException(status_code=422, detail=str(ve))

    except Exception as exc:
        masked_key = (
            f"***{authenticated_key[-4:]}"
            if authenticated_key and len(authenticated_key) >= 4
            else "***"
        )
        logger.error(
            f"Unhandled exception in feedback handler: {exc}",
            exc_info=True,
            extra={
                "api_key_last4": masked_key,
                "domain": getattr(payload, "domain", "unknown"),
            },
        )
        raise HTTPException(
            status_code=500,
            detail="Internal server error while processing event",
        )


